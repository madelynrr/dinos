<%= form_with(model: dino) do |form| %>
  <% if dino.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(dino.errors.count, "error") %> prohibited this dino from being saved:</h2>

      <ul>
        <% dino.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :category, style: "display: block" %>
    <%= form.select :category, Dino.categories.keys %>
  </div>

  <div>
    <%= form.label :period, style: "display: block" %>
    <%= form.select :period, Dino.periods.keys %>

  </div>

  <div>
    <%= form.label :diet, style: "display: block" %>
    <%= form.select :diet, Dino.diets.keys %>

  </div>

  <div>
    <%= form.label :age, style: "display: block" %>
    <%= form.number_field :age, required: true %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
